PROJECT_NAME="FollowmeeeAIGC API"
VERSION="1.0.0"

# Database
DATABASE_URL="sqlite:///./followmeeeaigc.db"

# Redis & Celery
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/0"

# JWT Auth
SECRET_KEY="your-super-secret-key-change-it-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440 # 24 hours

# AI API Flow2API settings
AI_API_URL="http://localhost:8088"
AI_API_KEY=""

MAX_RETRIES=3
